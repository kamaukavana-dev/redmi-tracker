# Required Environment Variables
# IMPORTANT: Replace ALL placeholder values with your own credentials
# Never commit real secrets to version control

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/redmi_tracker
API_KEY=<generate_secure_random_key_here>
TELEGRAM_BOT_TOKEN=<your_bot_token_from_botfather>
TELEGRAM_CHAT_ID=<your_chat_id>

# Optional Environment Variables
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=20
GEOFENCE_COOLDOWN_MINUTES=30
STRICT_STARTUP_VALIDATION=false
